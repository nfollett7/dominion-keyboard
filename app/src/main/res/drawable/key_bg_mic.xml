<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/key_mic_active" />
            <corners android:radius="@dimen/key_corner_radius" />
            <stroke android:width="1dp" android:color="#FF6699" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A0D1A" />
            <corners android:radius="@dimen/key_corner_radius" />
            <stroke android:width="1dp" android:color="@color/key_mic_active" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/key_mic_bg" />
            <corners android:radius="@dimen/key_corner_radius" />
            <stroke android:width="1dp" android:color="#7B2FFF" />
        </shape>
    </item>
</selector>
